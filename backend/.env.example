# UFIE Backend Environment Variables

# Database
DATABASE_URL=postgresql://ufie_user:ufie_pass@localhost:5432/ufie_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AI API Keys (optional - built-in AI works without these)
